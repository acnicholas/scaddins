<?xml version="1.0" encoding="utf-8"?>
<!--
  nullCarbon Revit Export — repo-pinned NuGet sources.

  Why this file exists:
    Some Windows machines (and CI runners) have no NuGet sources configured
    after a fresh dotnet SDK install (`dotnet nuget list source` returns
    "No sources found."). Restore then fails for every package with NU1100.

    Pinning nuget.org here makes restore work on any machine that clones the
    repo, regardless of the user's per-machine NuGet config. <clear /> wipes
    any inherited config from a parent directory or system-wide NuGet.config
    so we don't pick up broken/private feeds we don't need.

    This is a new file (upstream SCaddins doesn't have one) so it never
    causes merge conflicts when syncing from upstream.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
